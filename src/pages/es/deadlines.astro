---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, localeHome } from '../../i18n/ui';

const lang = 'es' as const;

interface Deadline {
  date: string;
  display: string;
  label: string;
  hint?: string;
}

const formArrival: Deadline[] = [
  { date: '2026-01-31', display: '31 de enero de 2026', label: 'Formularios W-2 de su empleador', hint: 'Los empleadores deben enviarlos antes de esta fecha.' },
  { date: '2026-01-31', display: '31 de enero de 2026', label: '1099-NEC para contratistas', hint: '¿Trabajador autónomo? Espere esto de cada cliente que le pague $600 o más.' },
  { date: '2026-01-31', display: '31 de enero de 2026', label: '1099-MISC, 1099-INT, 1099-DIV', hint: 'Intereses bancarios, dividendos, ingresos varios.' },
  { date: '2026-02-15', display: '15 de febrero de 2026', label: '1099-B de corredurías', hint: 'Resumen de ventas de inversiones.' },
  { date: '2026-03-15', display: '15 de marzo de 2026', label: 'K-1 de sociedades / S-corps', hint: 'Si tiene una participación en un pequeño negocio.' },
];

const filingDeadlines: Deadline[] = [
  { date: '2026-04-15', display: '15 de abril de 2026', label: 'Impuesto federal sobre la renta' },
  { date: '2026-04-15', display: '15 de abril de 2026', label: 'Impuesto estatal de Oregon' },
  { date: '2026-04-15', display: '15 de abril de 2026', label: 'Impuesto de las Artes de Portland', hint: 'Una cuota fija de $35 si califica.' },
  { date: '2026-04-15', display: '15 de abril de 2026', label: 'Preescolar Para Todos de Multnomah (PFA)' },
  { date: '2026-04-15', display: '15 de abril de 2026', label: 'Servicios de Vivienda de Apoyo de Metro (SHS)' },
];
---

<BaseLayout lang={lang} path="/deadlines" title="Fechas límite para el año fiscal 2025">
  <a href={localeHome(lang)} class="detail-back">← {t(lang, 'tax.back')}</a>

  <h1>{t(lang, 'deadlines.title')}</h1>
  <p class="lead">{t(lang, 'deadlines.lead')}</p>

  <div class="deadlines js-deadlines">
    <div class="deadlines__bulk">
      <div class="deadlines__bulk-actions">
        <button type="button" class="btn btn--ghost js-deadlines-select-all">Seleccionar todo</button>
        <button type="button" class="btn btn--ghost js-deadlines-select-none">Limpiar</button>
      </div>
      <button type="button" class="btn btn--primary js-deadlines-download" disabled>
        📅 <span class="js-deadlines-download-label">Descargar <span class="js-deadlines-count">0</span> seleccionado(s)</span>
      </button>
    </div>

    <div class="deadlines__group">
      <div class="deadlines__group-head">
        <h2>{t(lang, 'deadlines.section_forms')}</h2>
        <button type="button" class="btn btn--ghost js-deadlines-select-group" data-group="forms">Seleccionar grupo</button>
      </div>
      <ul class="deadlines__list">
        {formArrival.map((d) => (
          <li class="deadline-row">
            <label class="deadline-row__label">
              <input type="checkbox" class="deadline-row__check js-deadline-check"
                     data-date={d.date}
                     data-title={d.label}
                     data-desc={d.hint || ''}
                     data-group="forms" />
              <span class="deadline-row__main">
                <span class="deadline-row__date tabular">{d.display}</span>
                <span class="deadline-row__label-text">{d.label}</span>
                {d.hint && <span class="deadline-row__hint">{d.hint}</span>}
              </span>
            </label>
            <button type="button" class="btn btn--ghost btn--small js-calendar-add-deadline"
                    data-date={d.date}
                    data-title={d.label}
                    data-desc={d.hint || ''}>📅 Añadir</button>
          </li>
        ))}
      </ul>
    </div>

    <div class="deadlines__group">
      <div class="deadlines__group-head">
        <h2>{t(lang, 'deadlines.section_filing')}</h2>
        <button type="button" class="btn btn--ghost js-deadlines-select-group" data-group="filing">Seleccionar grupo</button>
      </div>
      <ul class="deadlines__list">
        {filingDeadlines.map((d) => (
          <li class="deadline-row">
            <label class="deadline-row__label">
              <input type="checkbox" class="deadline-row__check js-deadline-check"
                     data-date={d.date}
                     data-title={d.label}
                     data-desc={d.hint || ''}
                     data-group="filing" />
              <span class="deadline-row__main">
                <span class="deadline-row__date tabular">{d.display}</span>
                <span class="deadline-row__label-text">{d.label}</span>
                {d.hint && <span class="deadline-row__hint">{d.hint}</span>}
              </span>
            </label>
            <button type="button" class="btn btn--ghost btn--small js-calendar-add-deadline"
                    data-date={d.date}
                    data-title={d.label}
                    data-desc={d.hint || ''}>📅 Añadir</button>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>

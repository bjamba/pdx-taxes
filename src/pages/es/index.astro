---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusPill from '../../components/StatusPill.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import { t } from '../../i18n/ui';

const lang = 'es' as const;
const taxes = (await getCollection('taxes-es')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<BaseLayout lang={lang} path="" title={t(lang, 'site.tagline')}>
  <h1>{t(lang, 'site.tagline')}</h1>
  <p class="lead">{t(lang, 'home.lead')}</p>

  <Disclaimer lang={lang} />

  <h2>{t(lang, 'home.intro_title')}</h2>
  <p>{t(lang, 'home.intro_body')}</p>

  <div class="progress-bar js-progress" role="status" aria-label={t(lang, 'checklist.progress')}>
    <span class="progress-bar__label tabular">0/0</span>
    <div class="progress-bar__track" aria-hidden="true">
      <div class="progress-bar__fill" style="width: 0%"></div>
    </div>
  </div>

  <ul class="tax-list">
    {taxes.map((tax) => (
      <li>
        <a href={`/es/${tax.data.slug}`} class="tax-card">
          <div class="tax-card__top">
            <div>
              <div class="tax-card__title">{tax.data.name}</div>
              <div class="tax-card__juris">{t(lang, `jurisdiction.${tax.data.jurisdiction}` as any)}</div>
            </div>
            <StatusPill lang={lang} taxId={tax.data.id} />
          </div>
          <p class="tax-card__summary">{tax.data.summary}</p>
          <div class="tax-card__meta">
            <span><strong>{t(lang, 'tax.deadline')}:</strong> <span class="tabular">{tax.data.deadline}</span></span>
            <span><strong>{t(lang, 'tax.rate')}:</strong> {tax.data.rate_summary.split('.')[0]}</span>
          </div>
        </a>
      </li>
    ))}
  </ul>

  <p style="margin-top: var(--space-8); display: flex; gap: var(--space-3); align-items: center;">
    <button type="button" class="btn btn--ghost js-clear-checklist">{t(lang, 'checklist.clear')}</button>
    <span class="js-cleared-note" hidden style="font-size: 14px; color: var(--ink-soft);">{t(lang, 'checklist.cleared')}</span>
  </p>
</BaseLayout>

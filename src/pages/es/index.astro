---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import TaxDeck from '../../components/TaxDeck.astro';
import Welcome from '../../components/Welcome.astro';
import Survey from '../../components/Survey.astro';
import Result from '../../components/Result.astro';
import ViewToggle from '../../components/ViewToggle.astro';
import CalcPanel from '../../components/CalcPanel.astro';
import Celebration from '../../components/Celebration.astro';
import { t } from '../../i18n/ui';

const lang = 'es' as const;
const taxes = (await getCollection('taxes-es')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<BaseLayout lang={lang} path="" title="Impuestos locales de Portland en un solo lugar">
  <div data-page="home" data-state="loading">
    <Welcome lang={lang} />
    <Survey lang={lang} />
    <Result lang={lang} total={taxes.length} />
    <Celebration lang={lang} />

    <section class="hero hero--compact">
      <h1 class="hero__title">
        {t(lang, 'hero.title_a')} <em>{t(lang, 'hero.title_em')}</em> {t(lang, 'hero.title_b')}
      </h1>
    </section>

    <CalcPanel lang={lang} />
    <ViewToggle lang={lang} />
    <TaxDeck lang={lang} taxes={taxes} />

    <p class="clear-row js-clear-row">
      <button type="button" class="btn btn--ghost js-clear-checklist">{t(lang, 'checklist.clear')}</button>
      <button type="button" class="btn btn--ghost js-reset-all">Restablecer todo</button>
      <span class="cleared-note js-cleared-note" hidden>✓ {t(lang, 'checklist.cleared')}</span>
    </p>
  </div>
</BaseLayout>

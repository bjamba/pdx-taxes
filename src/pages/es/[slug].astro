---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SegmentedStatus from '../../components/SegmentedStatus.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import { t, localeHome } from '../../i18n/ui';

export async function getStaticPaths() {
  const taxes = await getCollection('taxes-es');
  return taxes.map((tax) => ({
    params: { slug: tax.data.slug },
    props: { tax },
  }));
}

const lang = 'es' as const;
const { tax } = Astro.props;
const data = tax.data;
const path = `/${data.slug}`;
---

<BaseLayout lang={lang} path={path} title={data.name} description={data.summary}>
  <a href={localeHome(lang)} class="detail-back">← {t(lang, 'tax.back')}</a>

  <span class="detail-juris-tag" data-juris={data.jurisdiction}>
    {t(lang, `jurisdiction.${data.jurisdiction}` as any)}
  </span>
  <h1>{data.name}</h1>
  <p class="lead">{data.summary}</p>

  <SegmentedStatus lang={lang} taxId={data.id} />

  <Disclaimer lang={lang} />

  <section class="detail-section">
    <h2>{t(lang, 'tax.who_owes')}</h2>
    <p>{data.who_owes}</p>
  </section>

  <section class="detail-section">
    <dl class="detail-defs">
      <div>
        <dt>{t(lang, 'tax.rate')}</dt>
        <dd>{data.rate_summary}</dd>
      </div>
      <div>
        <dt>{t(lang, 'tax.deadline')}</dt>
        <dd class="tabular">{data.deadline}</dd>
      </div>
    </dl>
  </section>

  <section class="detail-section">
    <h2>{t(lang, 'tax.filing')}</h2>
    <p>{data.filing_summary}</p>
    <div class="detail-actions">
      <a href={data.filing_url} class="btn btn--primary" target="_blank" rel="noopener">
        {t(lang, 'tax.file_button')} →
      </a>
    </div>
  </section>

  {data.friendly_note && (
    <aside class="callout callout--friendly">
      <p class="callout__title">☼ {t(lang, 'tax.friendly_note')}</p>
      <p>{data.friendly_note}</p>
    </aside>
  )}

  {data.free_filing.length > 0 && (
    <section class="detail-section">
      <h2>{t(lang, 'tax.free_filing')}</h2>
      <ul class="sources-list">
        {data.free_filing.map((r) => (
          <li><a href={r.url} target="_blank" rel="noopener">{r.name}</a></li>
        ))}
      </ul>
    </section>
  )}

  <section class="detail-section">
    <h2>{t(lang, 'tax.sources')}</h2>
    <ul class="sources-list">
      {data.sources.map((s) => (
        <li><a href={s.url} target="_blank" rel="noopener">{s.title}</a></li>
      ))}
    </ul>
  </section>

  <p class="verified">
    <span>{t(lang, 'tax.last_verified')}: <span class="tabular">{data.last_verified}</span></span>
  </p>
</BaseLayout>

---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChecklistScript from '../components/ChecklistScript.astro';
import '../styles/global.css';

interface Props {
  lang: Lang;
  path: string;
  title?: string;
  description?: string;
}

const { lang, path, title, description } = Astro.props;
const fullTitle = title ? `${title} — ${t(lang, 'site.name')}` : t(lang, 'site.name');
const desc = description ?? t(lang, 'site.tagline');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="color-scheme" content="light" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header lang={lang} path={path} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <ChecklistScript />
  </body>
</html>

---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  href: string;
  taxId: string;
  jurisdiction: 'city-of-portland' | 'multnomah-county' | 'metro';
  jurisdictionLabel: string;
  name: string;
  summary: string;
  rateSummary: string;
  deadline: string;
}

const { lang, href, taxId, jurisdiction, jurisdictionLabel, name, summary, rateSummary, deadline } = Astro.props;

const labels = {
  'not-started': t(lang, 'status.not_started'),
  'in-progress': t(lang, 'status.in_progress'),
  'done': t(lang, 'status.done'),
  'not-applicable': t(lang, 'status.not_applicable'),
};
---

<a href={href} class="tax-card" data-juris={jurisdiction} data-progress-id={taxId}>
  <span class="tax-card__status js-card-status" data-tax-id={taxId} data-labels={JSON.stringify(labels)}>
    <span class="tax-card__status-dot" aria-hidden="true"></span>
    <span class="tax-card__status-label">{labels['not-started']}</span>
  </span>

  <span class="tax-card__juris-tag">{jurisdictionLabel}</span>

  <h3 class="tax-card__title">{name}</h3>

  <p class="tax-card__summary">{summary}</p>

  <div class="tax-card__meta">
    <div>
      <strong>{t(lang, 'tax.rate')}</strong>
      <span>{rateSummary}</span>
    </div>
    <div>
      <strong>{t(lang, 'tax.deadline')}</strong>
      <span class="tabular">{deadline}</span>
    </div>
  </div>

  <span class="tax-card__cta">
    {t(lang, 'tax.see_details')}
    <span class="tax-card__cta-arrow" aria-hidden="true">→</span>
  </span>
</a>

---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  taxId: string;
  compact?: boolean;
}

const { lang, taxId, compact = false } = Astro.props;

const labels = {
  'not-started': t(lang, 'status.not_started'),
  'in-progress': t(lang, 'status.in_progress'),
  'done': t(lang, 'status.done'),
};
---

<div class={`status-control ${compact ? 'status-control--compact' : ''}`} data-tax-id={taxId} data-labels={JSON.stringify(labels)}>
  <span class="status-control__label">{t(lang, 'status.label')}</span>
  <div role="group" aria-label={t(lang, 'status.label')} class="segmented js-segmented">
    <button type="button" class="segmented__btn js-status-btn" data-status="not-started" aria-pressed="true">
      <span class="segmented__icon" aria-hidden="true">○</span>
      <span class="segmented__label">{labels['not-started']}</span>
    </button>
    <button type="button" class="segmented__btn js-status-btn" data-status="in-progress" aria-pressed="false">
      <span class="segmented__icon" aria-hidden="true">●</span>
      <span class="segmented__label">{labels['in-progress']}</span>
    </button>
    <button type="button" class="segmented__btn js-status-btn" data-status="done" aria-pressed="false">
      <span class="segmented__icon" aria-hidden="true">✓</span>
      <span class="segmented__label">{labels['done']}</span>
    </button>
  </div>
</div>

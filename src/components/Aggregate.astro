---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="aggregate js-aggregate">
  <div class="aggregate__inner">
    <div class="aggregate__text">
      <span class="aggregate__title">{t(lang, 'aggregate.title')}</span>
      <span class="aggregate__subtitle">{t(lang, 'aggregate.subtitle')}</span>
    </div>
    <div class="aggregate__amount-wrap">
      <span class="aggregate__amount tabular js-aggregate-amount">—</span>
    </div>
  </div>

  <!-- Chips populated client-side. One per applicable tax with a state class. -->
  <div class="aggregate__chips js-aggregate-chips" aria-label={t(lang, 'aggregate.contributing')}></div>
  <p class="aggregate__empty js-aggregate-empty">{t(lang, 'aggregate.empty')}</p>

  <div class="aggregate__actions">
    <button type="button" class="btn btn--ghost js-calendar-add-all">
      📅 {t(lang, 'calendar.add_all')}
    </button>
  </div>
</section>

---
/* Three-circles mark — represents the three jurisdictions overlapping. */
---
<svg
  class="brand-mark"
  viewBox="0 0 36 36"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <!-- Portland (moss) -->
  <circle cx="13" cy="14" r="9" fill="#3F6B4F" opacity="0.9" />
  <!-- Multnomah (terracotta) -->
  <circle cx="23" cy="14" r="9" fill="#B65235" opacity="0.85" style="mix-blend-mode: multiply" />
  <!-- Metro (ochre) -->
  <circle cx="18" cy="23" r="9" fill="#8E5F0F" opacity="0.85" style="mix-blend-mode: multiply" />
</svg>

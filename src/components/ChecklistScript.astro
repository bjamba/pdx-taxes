---
// Single client-side script: profile / state machine / checklist /
// shared estimator / aggregate / calendar. State in localStorage only.
---

<script is:inline>
  (function () {
    const KEY_CHECKLIST = 'pdx-taxes:checklist:v1';
    const KEY_PROFILE   = 'pdx-taxes:profile:v1';
    const KEY_CALC      = 'pdx-taxes:calc:v1'; // { filing: 'single'|'joint', income: number, artsExempt: boolean }

    const TAX_IDS = ['arts-tax', 'multnomah-pfa', 'metro-shs'];

    /* ── Storage ─────────────────────────────────────────── */
    const readJSON = (k) => {
      try { return JSON.parse(localStorage.getItem(k) || 'null') || null; }
      catch { return null; }
    };
    const writeJSON = (k, v) => { try { localStorage.setItem(k, JSON.stringify(v)); } catch {} };
    const remove   = (k) => { try { localStorage.removeItem(k); } catch {} };

    const readChecklist = () => {
      const j = readJSON(KEY_CHECKLIST);
      return (j && j.items) ? j.items : {};
    };
    const writeChecklist = (items) => writeJSON(KEY_CHECKLIST, { version: 1, items });
    const setStatus = (taxId, status) => {
      const items = readChecklist();
      items[taxId] = { status, updated_at: new Date().toISOString() };
      writeChecklist(items);
    };
    const getStatus = (taxId) => {
      const items = readChecklist();
      return (items[taxId] && items[taxId].status) || 'not-started';
    };

    const readProfile = () => readJSON(KEY_PROFILE);
    const writeProfile = (p) => writeJSON(KEY_PROFILE, p);

    const readCalc = () => readJSON(KEY_CALC) || { filing: 'single', income: null, artsExempt: false };
    const writeCalc = (v) => writeJSON(KEY_CALC, v);

    /* ── Applicability ─────────────────────────────────── */
    function appliesTo(taxId, p) {
      if (!p || p.showAll) return true;
      const inPortland = ['portland', 'unsure'].includes(p.residency);
      const inMultnomah = ['portland', 'multnomah', 'unsure'].includes(p.residency);
      const inMetro = p.residency !== 'outside';
      const overThreshold = ['mid', 'high', 'unsure'].includes(p.income);
      switch (taxId) {
        case 'arts-tax':       return inPortland;
        case 'multnomah-pfa':  return inMultnomah && overThreshold;
        case 'metro-shs':      return inMetro && overThreshold;
        default:               return true;
      }
    }

    /* ── Estimator math ────────────────────────────────── */
    function fmtUSD(n) {
      try { return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }); }
      catch { return '$' + Math.round(n).toLocaleString(); }
    }
    function computeArts(profile, calc) {
      const inPortland = profile && (profile.residency === 'portland' || profile.residency === 'unsure');
      if (!inPortland) return { applies: false, amount: 0, state: 'na' };
      if (calc && calc.artsExempt) return { applies: false, amount: 0, state: 'exempt' };
      return { applies: true, amount: 35, state: 'computed' };
    }
    function computePFA(filing, income) {
      const isJoint = filing === 'joint';
      const t1 = isJoint ? 200000 : 125000;
      const t2 = isJoint ? 400000 : 250000;
      const inc = Math.max(0, income || 0);
      if (inc <= t1) return { applies: false, amount: 0, state: 'below' };
      const band1 = Math.min(inc, t2) - t1;
      const band2 = Math.max(0, inc - t2);
      return { applies: true, amount: band1 * 0.015 + band2 * 0.030, state: 'computed' };
    }
    function computeSHS(filing, income) {
      const isJoint = filing === 'joint';
      const threshold = isJoint ? 205000 : 128000;
      const taxable = Math.max(0, (income || 0) - threshold);
      if (taxable === 0) return { applies: false, amount: 0, state: 'below' };
      return { applies: true, amount: taxable * 0.01, state: 'computed' };
    }

    /* ── State derivation ─────────────────────────────── */
    function deriveState() {
      const profile = readProfile();
      if (!profile) return { state: 'welcome', profile: null };
      const fallback = profile.showAll ? 'skipped' : 'result';
      return { state: doneStateOr(fallback, profile), profile };
    }
    function doneStateOr(fallback, profile) {
      const items = readChecklist();
      const cards = Array.from(document.querySelectorAll('[data-progress-id]'));
      const visible = cards.filter((c) => {
        const id = c.getAttribute('data-progress-id');
        if (!id) return false;
        if (!profile || profile.showAll) return true;
        return appliesTo(id, profile);
      });
      if (visible.length === 0) return fallback;
      const allHandled = visible.every((c) => {
        const id = c.getAttribute('data-progress-id');
        const s = (items[id] && items[id].status) || 'not-started';
        return s === 'done' || s === 'not-applicable';
      });
      return allHandled ? 'done' : fallback;
    }

    /* ── Renderers ─────────────────────────────────────── */

    function applyState() {
      const main = document.querySelector('[data-page="home"]');
      if (!main) return;
      const { state, profile } = deriveState();
      main.setAttribute('data-state', state);

      const deck = document.querySelector('.js-deck');
      if (deck) {
        if (profile && !profile.showAll) {
          deck.setAttribute('data-filter', 'on');
          deck.querySelectorAll('.deck__card').forEach((card) => {
            const id = card.getAttribute('data-progress-id');
            const applies = appliesTo(id, profile);
            card.setAttribute('data-applies', applies ? 'true' : 'false');
          });
          deck.querySelectorAll('.deck__dots > li').forEach((li, i) => {
            const card = deck.querySelector(`.deck__card[data-deck-index="${i}"]`);
            if (card) li.setAttribute('data-applies', card.getAttribute('data-applies') || 'true');
          });
        } else {
          deck.removeAttribute('data-filter');
          deck.querySelectorAll('.deck__card').forEach((c) => c.setAttribute('data-applies', 'true'));
          deck.querySelectorAll('.deck__dots > li').forEach((li) => li.setAttribute('data-applies', 'true'));
        }
        ensureDeckActive(deck);
      }

      // View toggle button states
      const filtered = profile && !profile.showAll;
      document.querySelectorAll('.js-view-toggle').forEach((btn) => {
        const target = btn.getAttribute('data-view');
        const active = (target === 'for-me' && filtered) || (target === 'all' && !filtered);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      // Disable "For me" if user has no preferences saved (skipped without answering)
      const forMeBtn = document.querySelector('.js-view-toggle[data-view="for-me"]');
      if (forMeBtn) {
        const hasPrefs = profile && (profile.residency || profile.filing || profile.income);
        forMeBtn.toggleAttribute('disabled', false); // always clickable; clicking with no prefs sends to survey
      }

      if (state === 'result') renderResultBanner(profile);
    }

    function ensureDeckActive(deck) {
      const cards = Array.from(deck.querySelectorAll('.deck__card'));
      const visible = cards.filter((c) => (c.getAttribute('data-applies') || 'true') !== 'false');
      if (visible.length === 0) { deck.setAttribute('data-empty', 'true'); return; }
      deck.setAttribute('data-empty', 'false');
      const activeIdx = cards.findIndex((c) => c.classList.contains('is-active'));
      const active = activeIdx >= 0 ? cards[activeIdx] : null;
      if (!active || (active.getAttribute('data-applies') || 'true') === 'false') {
        cards.forEach((c) => c.classList.remove('is-active'));
        visible[0].classList.add('is-active');
      }
      updateDeckChrome(deck);
    }

    function updateDeckChrome(deck) {
      const cards = Array.from(deck.querySelectorAll('.deck__card'));
      const visible = cards.filter((c) => (c.getAttribute('data-applies') || 'true') !== 'false');
      const activeIdx = cards.findIndex((c) => c.classList.contains('is-active'));
      const visibleActiveIdx = visible.findIndex((c) => c.classList.contains('is-active'));
      cards.forEach((c) => c.setAttribute('aria-hidden', c.classList.contains('is-active') ? 'false' : 'true'));
      deck.querySelectorAll('.deck__dot').forEach((dot, i) => dot.classList.toggle('is-active', i === activeIdx));
      const prev = deck.querySelector('.js-deck-prev');
      const next = deck.querySelector('.js-deck-next');
      if (prev) prev.toggleAttribute('disabled', visibleActiveIdx <= 0);
      if (next) next.toggleAttribute('disabled', visibleActiveIdx === -1 || visibleActiveIdx >= visible.length - 1);
    }

    function navDeck(delta) {
      const deck = document.querySelector('.js-deck');
      if (!deck) return;
      const cards = Array.from(deck.querySelectorAll('.deck__card'));
      const visible = cards.filter((c) => (c.getAttribute('data-applies') || 'true') !== 'false');
      if (visible.length === 0) return;
      const i = visible.findIndex((c) => c.classList.contains('is-active'));
      const next = Math.max(0, Math.min(visible.length - 1, i + delta));
      cards.forEach((c) => c.classList.remove('is-active'));
      visible[next].classList.add('is-active');
      updateDeckChrome(deck);
    }
    function gotoDeck(idx) {
      const deck = document.querySelector('.js-deck');
      if (!deck) return;
      const cards = Array.from(deck.querySelectorAll('.deck__card'));
      const target = cards[idx];
      if (!target || (target.getAttribute('data-applies') || 'true') === 'false') return;
      cards.forEach((c) => c.classList.remove('is-active'));
      target.classList.add('is-active');
      updateDeckChrome(deck);
    }

    function renderResultBanner(profile) {
      const result = document.querySelector('.js-result');
      if (!result) return;
      const total = parseInt(result.getAttribute('data-total') || '3', 10);
      const cards = Array.from(document.querySelectorAll('[data-progress-id]'));
      const applies = cards.filter((c) => appliesTo(c.getAttribute('data-progress-id'), profile));
      const n = applies.length;
      const titleEl = result.querySelector('.js-result-title');
      const bodyEl = result.querySelector('.js-result-body');
      const showAllBtn = result.querySelector('.js-result-show-all');
      if (!titleEl) return;
      const lang = (document.documentElement.getAttribute('lang') || 'en').slice(0, 2);
      const I18N = {
        en: { some: (n,t)=>`Looks like <strong>${n} of ${t}</strong> likely apply to you.`,
              all:  (n)=>`Looks like <strong>all ${n}</strong> likely apply to you.`,
              none: ()=>`Nothing local for you this year.`,
              noneBody: ()=>`Based on your answers, none of the three local taxes apply. (Federal and Oregon state taxes still do!)`,
              showAll: (t)=>`Show me all ${t} anyway` },
        es: { some: (n,t)=>`Parece que <strong>${n} de ${t}</strong> le aplican.`,
              all:  (n)=>`Parece que los <strong>${n}</strong> le aplican.`,
              none: ()=>`No hay impuestos locales para usted este año.`,
              noneBody: ()=>`Según sus respuestas, ninguno de los tres impuestos locales le aplica. (¡Los impuestos federal y estatal de Oregon sí!)`,
              showAll: (t)=>`Mostrar los ${t} de todos modos` },
      };
      const dict = I18N[lang] || I18N.en;
      if (n === 0) { titleEl.innerHTML = dict.none(); if (bodyEl) { bodyEl.textContent = dict.noneBody(); bodyEl.removeAttribute('hidden'); } }
      else if (n === total) { titleEl.innerHTML = dict.all(n); if (bodyEl) bodyEl.setAttribute('hidden', ''); }
      else { titleEl.innerHTML = dict.some(n, total); if (bodyEl) bodyEl.setAttribute('hidden', ''); }
      if (showAllBtn) showAllBtn.textContent = dict.showAll(total);
    }

    function renderCardBadges() {
      document.querySelectorAll('.js-card-status').forEach((badge) => {
        const taxId = badge.getAttribute('data-tax-id');
        if (!taxId) return;
        const status = getStatus(taxId);
        let labels = {};
        try { labels = JSON.parse(badge.getAttribute('data-labels') || '{}'); } catch {}
        badge.className = 'tax-card__status js-card-status' + (status !== 'not-started' ? ' tax-card__status--' + status : '');
        const dot = badge.querySelector('.tax-card__status-dot');
        const label = badge.querySelector('.tax-card__status-label');
        if (label) label.textContent = labels[status] || labels['not-started'] || '';
        if (dot) {
          dot.style.background = status === 'done' ? 'var(--portland)'
            : status === 'in-progress' ? 'var(--metro)'
            : 'var(--ink-faint)';
        }
      });
      // Same for deck cards
      document.querySelectorAll('.deck__card-status.js-card-status').forEach((badge) => {
        const taxId = badge.getAttribute('data-tax-id');
        if (!taxId) return;
        const status = getStatus(taxId);
        let labels = {};
        try { labels = JSON.parse(badge.getAttribute('data-labels') || '{}'); } catch {}
        badge.className = 'deck__card-status js-card-status' + (status !== 'not-started' ? ' deck__card-status--' + status : '');
        const label = badge.querySelector('.deck__card-status-label');
        if (label) label.textContent = labels[status] || labels['not-started'] || '';
      });
    }

    function renderSegmented() {
      document.querySelectorAll('.status-control').forEach((root) => {
        const taxId = root.getAttribute('data-tax-id');
        if (!taxId) return;
        const status = getStatus(taxId);
        root.querySelectorAll('.js-status-btn').forEach((btn) => {
          const s = btn.getAttribute('data-status');
          btn.setAttribute('aria-pressed', s === status ? 'true' : 'false');
        });
      });
    }

    function renderProgress() {
      const items = readChecklist();
      const profile = readProfile();
      const cards = Array.from(document.querySelectorAll('[data-progress-id]'));
      const visible = cards.filter((c) => {
        const id = c.getAttribute('data-progress-id');
        return !profile || profile.showAll || appliesTo(id, profile);
      });
      const ids = Array.from(new Set(visible.map((c) => c.getAttribute('data-progress-id')).filter(Boolean)));
      const total = ids.length;
      const handled = ids.filter((id) => {
        const it = items[id];
        return it && (it.status === 'done' || it.status === 'not-applicable');
      }).length;
      const pct = total === 0 ? 0 : Math.round((handled / total) * 100);

      // Header progress badge (compact)
      const headerProgress = document.querySelector('.js-status-progress');
      if (headerProgress) {
        if (total === 0) { headerProgress.setAttribute('hidden', ''); }
        else {
          headerProgress.removeAttribute('hidden');
          const fill = headerProgress.querySelector('.js-status-progress-fill');
          const text = headerProgress.querySelector('.js-status-progress-text');
          if (fill) fill.style.width = pct + '%';
          if (text) text.textContent = `${handled}/${total}`;
        }
      }
    }

    /* ── Card-level estimate slot + aggregate ─────────── */

    function renderEstimates() {
      const profile = readProfile();
      const calc = readCalc();
      const filing = calc.filing || 'single';
      const income = (calc.income == null) ? null : Number(calc.income);
      const lang = (document.documentElement.getAttribute('lang') || 'en').slice(0, 2);

      const I18N = {
        en: { empty: 'Tap "Estimate" to see what you might owe',
              below: 'Below the threshold — you don\'t owe this',
              na: 'You marked this as not applicable',
              naProfile: 'Doesn\'t apply based on your answers',
              exempt: 'You\'re exempt from this tax' },
        es: { empty: 'Toque "Estimar" para ver lo que podría deber',
              below: 'Por debajo del umbral — no debe esto',
              na: 'Lo marcó como no aplicable',
              naProfile: 'No aplica según sus respuestas',
              exempt: 'Está exento de este impuesto' },
      };
      const dict = I18N[lang] || I18N.en;

      // Per-tax results
      const results = {};
      TAX_IDS.forEach((id) => {
        let r;
        if (id === 'arts-tax')          r = computeArts(profile, calc);
        else if (id === 'multnomah-pfa') r = (income == null) ? { applies: null, amount: 0, state: 'empty' } : computePFA(filing, income);
        else if (id === 'metro-shs')     r = (income == null) ? { applies: null, amount: 0, state: 'empty' } : computeSHS(filing, income);
        // Override: user marked NA
        const status = getStatus(id);
        if (status === 'not-applicable') r = { applies: false, amount: 0, state: 'na', userNa: true };
        // Override: profile excludes
        if (profile && !profile.showAll && !appliesTo(id, profile)) {
          r = { applies: false, amount: 0, state: 'na', profileNa: true };
        }
        results[id] = r;

        // Render the card slot
        const slot = document.querySelector(`.js-card-est[data-tax-id="${id}"]`);
        if (!slot) return;
        const amountEl = slot.querySelector('.js-card-est-amount');
        const hintEl = slot.querySelector('.js-card-est-hint');

        if (r.state === 'computed') {
          slot.setAttribute('data-state', 'computed');
          if (amountEl) amountEl.textContent = fmtUSD(Math.ceil(r.amount));
          if (hintEl) hintEl.textContent = '';
        } else if (r.state === 'below') {
          slot.setAttribute('data-state', 'below');
          if (amountEl) amountEl.textContent = '$0';
          if (hintEl) hintEl.textContent = dict.below;
        } else if (r.state === 'exempt') {
          slot.setAttribute('data-state', 'exempt');
          if (amountEl) amountEl.textContent = '$0';
          if (hintEl) hintEl.textContent = dict.exempt;
        } else if (r.state === 'na') {
          slot.setAttribute('data-state', 'na');
          if (amountEl) amountEl.textContent = '—';
          if (hintEl) hintEl.textContent = r.userNa ? dict.na : dict.naProfile;
        } else {
          slot.setAttribute('data-state', 'empty');
          if (amountEl) amountEl.textContent = '—';
          if (hintEl) hintEl.textContent = dict.empty;
        }
      });

      renderAggregate(results, profile);
    }

    function renderAggregate(results, profile) {
      // Compute total of computed (applicable, non-NA) estimates.
      const applicableIds = TAX_IDS.filter((id) => !profile || profile.showAll || appliesTo(id, profile));
      let total = 0;
      let anyComputed = false;
      applicableIds.forEach((id) => {
        const r = results[id];
        if (r && r.state === 'computed') { total += r.amount; anyComputed = true; }
      });

      // Update sticky header total badge.
      const headerTotal = document.querySelector('.js-status-total');
      const amountEl = document.querySelector('.js-status-total-amount');
      if (headerTotal && amountEl) {
        if (anyComputed) {
          headerTotal.removeAttribute('hidden');
          amountEl.textContent = fmtUSD(Math.ceil(total));
        } else {
          headerTotal.setAttribute('hidden', '');
        }
      }
    }

    /* ── CalcPanel: read inputs, persist, render ──────── */

    function syncCalcPanel() {
      const calc = readCalc();
      const filingEls = document.querySelectorAll('.js-calc-filing');
      filingEls.forEach((el) => {
        if (el.value === (calc.filing || 'single')) el.checked = true;
      });
      const incomeEl = document.querySelector('.js-calc-income');
      if (incomeEl && calc.income != null) incomeEl.value = String(calc.income);
      const exemptEl = document.querySelector('.js-calc-arts-exempt');
      if (exemptEl) exemptEl.checked = !!calc.artsExempt;
    }

    function readCalcFromUI() {
      const filingEl = document.querySelector('.js-calc-filing:checked');
      const incomeEl = document.querySelector('.js-calc-income');
      const exemptEl = document.querySelector('.js-calc-arts-exempt');
      const filing = filingEl ? filingEl.value : 'single';
      const incomeStr = incomeEl ? incomeEl.value : '';
      const income = incomeStr === '' ? null : (parseFloat(incomeStr) || 0);
      const artsExempt = !!(exemptEl && exemptEl.checked);
      return { filing, income, artsExempt };
    }

    function onCalcChange() {
      writeCalc(readCalcFromUI());
      renderEstimates();
    }

    function clearCalcIncome() {
      const incomeEl = document.querySelector('.js-calc-income');
      if (incomeEl) incomeEl.value = '';
      onCalcChange();
    }

    /* ── Calendar (.ics) ─────────────────────────────── */
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function nowStamp() {
      const d = new Date();
      return d.getUTCFullYear() + pad(d.getUTCMonth()+1) + pad(d.getUTCDate()) + 'T' + pad(d.getUTCHours()) + pad(d.getUTCMinutes()) + pad(d.getUTCSeconds()) + 'Z';
    }
    function parseDeadline(text) {
      const en = /^(\w+) (\d{1,2}),\s*(\d{4})$/;
      const months = {january:1,february:2,march:3,april:4,may:5,june:6,july:7,august:8,september:9,october:10,november:11,december:12};
      const m = text.match(en);
      if (m) { const mo = months[m[1].toLowerCase()]; if (mo) return `${m[3]}-${pad(mo)}-${pad(parseInt(m[2],10))}`; }
      const esRe = /^(\d{1,2})\s+de\s+(\w+)\s+de\s+(\d{4})$/i;
      const monthsEs = {enero:1,febrero:2,marzo:3,abril:4,mayo:5,junio:6,julio:7,agosto:8,septiembre:9,octubre:10,noviembre:11,diciembre:12};
      const me = text.match(esRe);
      if (me) { const mo = monthsEs[me[2].toLowerCase()]; if (mo) return `${me[3]}-${pad(mo)}-${pad(parseInt(me[1],10))}`; }
      return null;
    }
    function escIcs(s) { return String(s).replace(/\\/g,'\\\\').replace(/;/g,'\\;').replace(/,/g,'\\,').replace(/\r?\n/g,'\\n'); }
    function buildICS(events) {
      const lines = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//pdx-taxes//community resource//EN','CALSCALE:GREGORIAN','METHOD:PUBLISH'];
      events.forEach((ev) => {
        const dt = ev.date.replace(/-/g,'');
        const end = new Date(ev.date + 'T00:00:00Z'); end.setUTCDate(end.getUTCDate()+1);
        const endStr = end.getUTCFullYear() + pad(end.getUTCMonth()+1) + pad(end.getUTCDate());
        lines.push('BEGIN:VEVENT', `UID:${ev.uid}@pdx-taxes.bjamba.github.io`, `DTSTAMP:${nowStamp()}`, `DTSTART;VALUE=DATE:${dt}`, `DTEND;VALUE=DATE:${endStr}`, `SUMMARY:${escIcs(ev.title)}`);
        if (ev.description) lines.push(`DESCRIPTION:${escIcs(ev.description)}`);
        if (ev.url) lines.push(`URL:${ev.url}`);
        (ev.remindersDays || []).forEach((d) => lines.push('BEGIN:VALARM', `TRIGGER:-P${d}D`, 'ACTION:DISPLAY', `DESCRIPTION:${escIcs(ev.title)}`, 'END:VALARM'));
        lines.push('END:VEVENT');
      });
      lines.push('END:VCALENDAR');
      return lines.join('\r\n') + '\r\n';
    }
    function downloadICS(filename, events) {
      const blob = new Blob([buildICS(events)], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename;
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }
    function flashCalendarFeedback(btn) {
      const original = btn.innerHTML;
      btn.innerHTML = '✓ Downloaded';
      setTimeout(() => { btn.innerHTML = original; }, 1800);
    }

    /* ── Top-level render ──────────────────────────── */

    function renderAll() {
      applyState();
      renderCardBadges();
      renderSegmented();
      renderProgress();
      renderEstimates();
      // Reveal header status badges on the home page (not detail / deadlines)
      const main = document.querySelector('[data-page="home"]');
      const headerStatus = document.querySelector('.js-status-badges');
      if (headerStatus) {
        if (main) headerStatus.removeAttribute('hidden');
        else headerStatus.setAttribute('hidden', '');
      }
    }

    function setMain(state) {
      const main = document.querySelector('[data-page="home"]');
      if (main) main.setAttribute('data-state', state);
    }

    function scrollToTopOfDeck() {
      const target = document.querySelector('.js-result, .js-deck, .js-calc-panel');
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* ── Bind ──────────────────────────────────────── */

    function bind() {
      // Status segments
      document.querySelectorAll('.js-status-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const root = btn.closest('.status-control');
          const taxId = root && root.getAttribute('data-tax-id');
          const status = btn.getAttribute('data-status');
          if (!taxId || !status) return;
          setStatus(taxId, status);
          renderAll();
        });
      });

      // Deck nav
      const prev = document.querySelector('.js-deck-prev');
      if (prev) prev.addEventListener('click', () => navDeck(-1));
      const next = document.querySelector('.js-deck-next');
      if (next) next.addEventListener('click', () => navDeck(1));
      document.querySelectorAll('.deck__dot').forEach((dot) => {
        dot.addEventListener('click', () => gotoDeck(parseInt(dot.getAttribute('data-deck-go') || '0', 10)));
      });
      const deck = document.querySelector('.js-deck');
      if (deck) {
        document.addEventListener('keydown', (e) => {
          if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT')) return;
          if (e.key === 'ArrowLeft') navDeck(-1);
          if (e.key === 'ArrowRight') navDeck(1);
        });
      }

      // Welcome
      const startBtn = document.querySelector('.js-welcome-start');
      if (startBtn) startBtn.addEventListener('click', () => setMain('survey'));
      const skipBtn = document.querySelector('.js-welcome-skip');
      if (skipBtn) skipBtn.addEventListener('click', () => {
        // No survey answers yet — pure "show all" with no other context.
        writeProfile({ showAll: true });
        renderAll();
        scrollToTopOfDeck();
      });

      // Survey
      const form = document.querySelector('.js-survey-form');
      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const fd = new FormData(form);
          writeProfile({
            residency: String(fd.get('residency') || 'unsure'),
            filing:    String(fd.get('filing') || 'unsure'),
            income:    String(fd.get('income') || 'unsure'),
          });
          // Carry filing into calc state if user picked single/joint
          const filing = String(fd.get('filing') || 'unsure');
          if (filing === 'single' || filing === 'joint') {
            const cur = readCalc();
            writeCalc({ filing, income: cur.income });
          }
          renderAll();
          syncCalcPanel();
          scrollToTopOfDeck();
        });
        const back = form.querySelector('.js-survey-skip');
        if (back) back.addEventListener('click', () => { writeProfile({ showAll: true }); renderAll(); scrollToTopOfDeck(); });
      }

      // Result banner — preserve original profile fields when adding showAll
      const showAllBtn = document.querySelector('.js-result-show-all');
      if (showAllBtn) showAllBtn.addEventListener('click', () => {
        const cur = readProfile() || {};
        writeProfile({ ...cur, showAll: true });
        renderAll();
      });
      const editBtn = document.querySelector('.js-result-edit');
      if (editBtn) editBtn.addEventListener('click', () => { remove(KEY_PROFILE); setMain('survey'); });
      const skippedEdit = document.querySelector('.js-skipped-edit');
      if (skippedEdit) skippedEdit.addEventListener('click', () => { remove(KEY_PROFILE); setMain('survey'); });

      // Persistent view toggle (lives above the deck)
      document.querySelectorAll('.js-view-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-view'); // 'for-me' | 'all'
          const cur = readProfile() || {};
          if (target === 'all') {
            writeProfile({ ...cur, showAll: true });
          } else {
            // Switching back to filtered — drop showAll, keep the rest. If
            // there's nothing else (e.g. user originally skipped), reset to
            // welcome so they can answer questions.
            const { showAll, ...rest } = cur;
            if (rest && rest.residency) writeProfile(rest);
            else { remove(KEY_PROFILE); setMain('survey'); }
          }
          renderAll();
        });
      });

      // Clear progress
      const clearBtn = document.querySelector('.js-clear-checklist');
      if (clearBtn) clearBtn.addEventListener('click', (e) => {
        e.preventDefault();
        remove(KEY_CHECKLIST);
        renderAll();
        const note = document.querySelector('.js-cleared-note');
        if (note) { note.removeAttribute('hidden'); setTimeout(() => note.setAttribute('hidden', ''), 2500); }
      });

      // Reset everything (profile + checklist + calc state)
      const resetBtn = document.querySelector('.js-reset-all');
      if (resetBtn) resetBtn.addEventListener('click', (e) => {
        e.preventDefault();
        remove(KEY_CHECKLIST);
        remove(KEY_PROFILE);
        remove(KEY_CALC);
        // Re-sync the now-empty calc panel UI
        const incomeEl = document.querySelector('.js-calc-income');
        if (incomeEl) incomeEl.value = '';
        const exemptEl = document.querySelector('.js-calc-arts-exempt');
        if (exemptEl) exemptEl.checked = false;
        const singleEl = document.querySelector('.js-calc-filing[value="single"]');
        if (singleEl) singleEl.checked = true;
        renderAll();
        const note = document.querySelector('.js-cleared-note');
        if (note) { note.removeAttribute('hidden'); setTimeout(() => note.setAttribute('hidden', ''), 2500); }
      });

      // CalcPanel inputs
      document.querySelectorAll('.js-calc-filing').forEach((r) => r.addEventListener('change', onCalcChange));
      const incomeEl = document.querySelector('.js-calc-income');
      if (incomeEl) {
        incomeEl.addEventListener('input', onCalcChange);
        incomeEl.addEventListener('change', onCalcChange);
      }
      const clearIncomeBtn = document.querySelector('.js-calc-clear');
      if (clearIncomeBtn) clearIncomeBtn.addEventListener('click', clearCalcIncome);
      const exemptEl = document.querySelector('.js-calc-arts-exempt');
      if (exemptEl) exemptEl.addEventListener('change', onCalcChange);

      // Calc modal — open / close
      const modal = document.querySelector('.js-calc-modal');
      const trigger = document.querySelector('.js-calc-trigger');
      let lastFocus = null;
      function openCalc() {
        if (!modal) return;
        lastFocus = document.activeElement;
        modal.removeAttribute('hidden');
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        if (trigger) trigger.setAttribute('aria-expanded', 'true');
        // Focus the income field for instant typing
        setTimeout(() => {
          const inc = modal.querySelector('.js-calc-income');
          if (inc) inc.focus();
        }, 50);
      }
      function closeCalc() {
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('hidden', '');
        document.body.style.overflow = '';
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }
      if (trigger) trigger.addEventListener('click', openCalc);
      document.querySelectorAll('.js-calc-close, .js-calc-close-overlay').forEach((el) => {
        el.addEventListener('click', closeCalc);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal && modal.classList.contains('is-open')) closeCalc();
      });

      // Calendar — single
      document.querySelectorAll('.js-calendar-add').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault(); e.stopPropagation();
          const id = btn.getAttribute('data-tax-id');
          const name = btn.getAttribute('data-tax-name');
          const deadline = btn.getAttribute('data-tax-deadline');
          const url = btn.getAttribute('data-tax-url');
          const iso = parseDeadline(deadline || '');
          if (!iso) return;
          downloadICS(`${id}-deadline.ics`, [{ uid: `${id}-${iso}`, date: iso, title: `${name} — file by today`, description: 'Filing deadline. Heads up from pdx-taxes.', url, remindersDays: [14, 1] }]);
          flashCalendarFeedback(btn);
        });
      });
      // Calendar — all
      document.querySelectorAll('.js-calendar-add-all').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const profile = readProfile();
          const cards = Array.from(document.querySelectorAll('.deck__card'));
          const events = [];
          cards.forEach((card) => {
            const id = card.getAttribute('data-progress-id');
            const visible = !profile || profile.showAll || appliesTo(id, profile);
            if (!visible) return;
            const name = card.querySelector('.deck__card-title');
            const dlEl = card.querySelector('.deck__card-defs dd.tabular');
            const deadline = dlEl ? dlEl.textContent.trim() : '';
            const iso = parseDeadline(deadline);
            if (!iso || !name) return;
            events.push({ uid: `${id}-${iso}`, date: iso, title: `${name.textContent.trim()} — file by today`, description: 'Filing deadline. Heads up from pdx-taxes.', remindersDays: [14, 1] });
          });
          if (events.length === 0) return;
          downloadICS('pdx-taxes-deadlines.ics', events);
          flashCalendarFeedback(btn);
        });
      });
      // Deadlines page — single row download
      document.querySelectorAll('.js-calendar-add-deadline').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const date = btn.getAttribute('data-date');
          const title = btn.getAttribute('data-title') || 'Deadline';
          if (!date) return;
          downloadICS(`${title.toLowerCase().replace(/\s+/g, '-')}.ics`, [{ uid: `${title}-${date}`, date, title, description: btn.getAttribute('data-desc') || '', remindersDays: [14, 1] }]);
          flashCalendarFeedback(btn);
        });
      });

      // Deadlines page — checkbox selection + bulk download
      const dlPage = document.querySelector('.js-deadlines');
      if (dlPage) {
        const downloadBtn = dlPage.querySelector('.js-deadlines-download');
        const countEl = dlPage.querySelector('.js-deadlines-count');
        const updateSelectionUI = () => {
          const checked = dlPage.querySelectorAll('.js-deadline-check:checked');
          if (countEl) countEl.textContent = String(checked.length);
          if (downloadBtn) downloadBtn.toggleAttribute('disabled', checked.length === 0);
        };
        dlPage.querySelectorAll('.js-deadline-check').forEach((cb) => {
          cb.addEventListener('change', updateSelectionUI);
        });
        const selectAll = dlPage.querySelector('.js-deadlines-select-all');
        if (selectAll) selectAll.addEventListener('click', () => {
          dlPage.querySelectorAll('.js-deadline-check').forEach((cb) => cb.checked = true);
          updateSelectionUI();
        });
        const selectNone = dlPage.querySelector('.js-deadlines-select-none');
        if (selectNone) selectNone.addEventListener('click', () => {
          dlPage.querySelectorAll('.js-deadline-check').forEach((cb) => cb.checked = false);
          updateSelectionUI();
        });
        dlPage.querySelectorAll('.js-deadlines-select-group').forEach((btn) => {
          btn.addEventListener('click', () => {
            const group = btn.getAttribute('data-group');
            dlPage.querySelectorAll(`.js-deadline-check[data-group="${group}"]`).forEach((cb) => cb.checked = true);
            updateSelectionUI();
          });
        });
        if (downloadBtn) {
          downloadBtn.addEventListener('click', () => {
            const events = [];
            dlPage.querySelectorAll('.js-deadline-check:checked').forEach((cb) => {
              const date = cb.getAttribute('data-date');
              const title = cb.getAttribute('data-title') || 'Deadline';
              const desc = cb.getAttribute('data-desc') || '';
              if (!date) return;
              events.push({ uid: `${title}-${date}`, date, title, description: desc, remindersDays: [14, 1] });
            });
            if (events.length === 0) return;
            downloadICS('pdx-taxes-deadlines.ics', events);
            flashCalendarFeedback(downloadBtn);
          });
        }
        updateSelectionUI();
      }
    }

    function init() {
      try {
        syncCalcPanel();
        renderAll();
        bind();
      } catch (err) {
        // Defensive: if anything throws, at least reveal the page so the user
        // isn't staring at a blank screen.
        const main = document.querySelector('[data-page="home"]');
        if (main && main.getAttribute('data-state') === 'loading') {
          const profile = readProfile();
          main.setAttribute('data-state', profile ? 'skipped' : 'welcome');
        }
        // Re-throw so the error shows in console for debugging.
        throw err;
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

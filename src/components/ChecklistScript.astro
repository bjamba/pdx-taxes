---
// Client-only checklist + status control. State lives in localStorage.
---

<script is:inline>
  (function () {
    const STORAGE_KEY = 'pdx-taxes:checklist:v1';

    function read() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return (parsed && typeof parsed === 'object' && parsed.items) ? parsed.items : {};
      } catch { return {}; }
    }
    function write(items) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify({ version: 1, items })); } catch {}
    }
    function clear() {
      try { localStorage.removeItem(STORAGE_KEY); } catch {}
    }
    function setStatus(taxId, status) {
      const items = read();
      items[taxId] = { status, updated_at: new Date().toISOString() };
      write(items);
    }
    function getStatus(taxId) {
      const items = read();
      return (items[taxId] && items[taxId].status) || 'not-started';
    }

    const STATUS_ICONS = { 'not-started': '○', 'in-progress': '●', 'done': '✓', 'not-applicable': '—' };

    /* Render the small status badge on tax cards (home page) */
    function renderCardBadges() {
      document.querySelectorAll('.js-card-status').forEach((badge) => {
        const taxId = badge.getAttribute('data-tax-id');
        if (!taxId) return;
        const status = getStatus(taxId);
        let labels = {};
        try { labels = JSON.parse(badge.getAttribute('data-labels') || '{}'); } catch {}
        badge.className = 'tax-card__status js-card-status' + (status !== 'not-started' ? ' tax-card__status--' + status : '');
        const dot = badge.querySelector('.tax-card__status-dot');
        const label = badge.querySelector('.tax-card__status-label');
        if (label) label.textContent = labels[status] || labels['not-started'] || '';
        if (dot) dot.style.background = (status === 'done' ? 'var(--portland)' :
                                         status === 'in-progress' ? 'var(--metro)' :
                                         status === 'not-applicable' ? 'var(--ink-faint)' :
                                         'var(--ink-faint)');
      });
    }

    /* Render the segmented control on detail pages */
    function renderSegmented() {
      document.querySelectorAll('.status-control').forEach((root) => {
        const taxId = root.getAttribute('data-tax-id');
        if (!taxId) return;
        const status = getStatus(taxId);
        const seg = root.querySelector('.js-segmented');
        const naToggle = root.querySelector('.js-status-na');
        const naActive = root.querySelector('.js-status-na-active');
        if (!seg || !naToggle || !naActive) return;
        if (status === 'not-applicable') {
          seg.setAttribute('hidden', '');
          naToggle.setAttribute('hidden', '');
          naActive.removeAttribute('hidden');
        } else {
          seg.removeAttribute('hidden');
          naToggle.removeAttribute('hidden');
          naActive.setAttribute('hidden', '');
          root.querySelectorAll('.js-status-btn').forEach((btn) => {
            const s = btn.getAttribute('data-status');
            btn.setAttribute('aria-pressed', s === status ? 'true' : 'false');
          });
        }
      });
    }

    /* Render progress bar */
    function renderProgress() {
      const bar = document.querySelector('.js-progress');
      if (!bar) return;
      const items = read();
      const ids = Array.from(document.querySelectorAll('[data-progress-id]'))
        .map((el) => el.getAttribute('data-progress-id'))
        .filter(Boolean);
      const uniq = Array.from(new Set(ids));
      const total = uniq.length;
      if (total === 0) return;
      const handled = uniq.filter((id) => {
        const it = items[id];
        return it && (it.status === 'done' || it.status === 'not-applicable');
      }).length;
      const fill = bar.querySelector('.progress__fill');
      const count = bar.querySelector('.progress__count');
      const pct = Math.round((handled / total) * 100);
      if (fill) fill.style.width = pct + '%';
      if (count) count.textContent = handled + ' / ' + total;
    }

    function renderAll() {
      renderCardBadges();
      renderSegmented();
      renderProgress();
    }

    function bind() {
      document.querySelectorAll('.js-status-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const root = btn.closest('.status-control');
          if (!root) return;
          const taxId = root.getAttribute('data-tax-id');
          const status = btn.getAttribute('data-status');
          if (!taxId || !status) return;
          setStatus(taxId, status);
          renderAll();
        });
      });
      document.querySelectorAll('.js-na-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
          const root = btn.closest('.status-control');
          if (!root) return;
          const taxId = root.getAttribute('data-tax-id');
          if (!taxId) return;
          setStatus(taxId, 'not-applicable');
          renderAll();
        });
      });
      document.querySelectorAll('.js-na-undo').forEach((btn) => {
        btn.addEventListener('click', () => {
          const root = btn.closest('.status-control');
          if (!root) return;
          const taxId = root.getAttribute('data-tax-id');
          if (!taxId) return;
          setStatus(taxId, 'not-started');
          renderAll();
        });
      });
      const clearBtn = document.querySelector('.js-clear-checklist');
      if (clearBtn) {
        clearBtn.addEventListener('click', (e) => {
          e.preventDefault();
          clear();
          renderAll();
          const note = document.querySelector('.js-cleared-note');
          if (note) {
            note.removeAttribute('hidden');
            setTimeout(() => note.setAttribute('hidden', ''), 2500);
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => { renderAll(); bind(); });
    } else {
      renderAll();
      bind();
    }
  })();
</script>

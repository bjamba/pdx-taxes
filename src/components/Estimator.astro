---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  taxId: string;
  /** Which calculator to render */
  type: 'arts' | 'pfa' | 'shs';
}

const { lang, taxId, type } = Astro.props;
---

<details class="estimator js-estimator" data-tax-id={taxId} data-calc-type={type} on:click="event.stopPropagation()">
  <summary class="estimator__summary">
    <span class="estimator__icon" aria-hidden="true">→</span>
    <span class="estimator__title">{t(lang, 'estimator.toggle')}</span>
    <span class="estimator__amount js-estimator-amount" hidden></span>
  </summary>

  <div class="estimator__body">
    {type === 'arts' && (
      <div class="estimator__row">
        <fieldset class="estimator__field">
          <legend>{t(lang, 'estimator.arts_q')}</legend>
          <label class="estimator__check">
            <input type="checkbox" class="js-arts-qual" />
            <span>{t(lang, 'estimator.arts_yes')}</span>
          </label>
        </fieldset>
      </div>
    )}

    {(type === 'pfa' || type === 'shs') && (
      <div class="estimator__row estimator__row--two">
        <fieldset class="estimator__field">
          <legend>{t(lang, 'estimator.filing')}</legend>
          <label class="estimator__radio"><input type="radio" name={`${taxId}-filing`} value="single" checked /><span>{t(lang, 'survey.q2_single')}</span></label>
          <label class="estimator__radio"><input type="radio" name={`${taxId}-filing`} value="joint" /><span>{t(lang, 'survey.q2_joint')}</span></label>
        </fieldset>
        <label class="estimator__field">
          <span class="estimator__legend">{t(lang, 'estimator.income')}</span>
          <span class="estimator__input-wrap">
            <span class="estimator__currency">$</span>
            <input type="number" class="estimator__input js-income-input" placeholder="0" inputmode="numeric" min="0" />
          </span>
          <span class="estimator__hint">{t(lang, 'estimator.income_hint')}</span>
        </label>
      </div>
    )}

    <div class="estimator__result js-estimator-result" hidden>
      <span class="estimator__result-label">{t(lang, 'estimator.estimate')}:</span>
      <strong class="estimator__result-amount tabular js-estimator-result-amount">$0</strong>
      <p class="estimator__reason js-estimator-reason"></p>
    </div>

    <p class="estimator__disclaim">
      ⓘ {t(lang, 'disclaimer.short')}
    </p>
  </div>
</details>

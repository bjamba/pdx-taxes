---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import Survey from './Survey.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<button type="button" class="calc-trigger js-calc-trigger" aria-haspopup="dialog" aria-expanded="false">
  <span class="calc-trigger__icon" aria-hidden="true">📊</span>
  <span class="calc-trigger__text">
    <span class="calc-trigger__title">{t(lang, 'calc.trigger_title')}</span>
    <span class="calc-trigger__lead">{t(lang, 'calc.trigger_lead')}</span>
  </span>
</button>

<div class="calc-modal js-calc-modal" role="dialog" aria-modal="true" aria-labelledby="calc-modal-title" hidden>
  <div class="calc-modal__overlay js-calc-close-overlay"></div>

  <div class="calc-modal__panel" role="document">
    <div class="calc-modal__head">
      <h2 id="calc-modal-title" class="calc-modal__title">{t(lang, 'calc.modal_title')}</h2>
      <button type="button" class="calc-modal__close js-calc-close" aria-label={t(lang, 'calc.close')}>×</button>
    </div>

    <!-- Same survey component as in-page; rendered with a `survey--in-modal` wrapper
         so we can hide the secondary skip button and close the modal on submit. -->
    <div class="survey--in-modal">
      <Survey lang={lang} />

      <fieldset class="survey__q survey__q--exempt">
        <legend class="survey__legend">{t(lang, 'calc.arts_legend')}</legend>
        <label class="calc-exempt">
          <input type="checkbox" class="js-modal-arts-exempt" />
          <span class="calc-exempt__main">
            <span class="calc-exempt__title">{t(lang, 'calc.arts_exempt_label')}</span>
            <span class="calc-exempt__hint">{t(lang, 'calc.arts_exempt_hint')}</span>
          </span>
        </label>
      </fieldset>
    </div>
  </div>
</div>

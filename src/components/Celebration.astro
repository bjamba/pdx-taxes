---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="celebration js-celebration">
  <svg class="celebration__mark" viewBox="0 0 56 56" aria-hidden="true" focusable="false">
    <circle cx="28" cy="28" r="26" fill="#D7E4D8" stroke="#3F6B4F" stroke-width="2.5" />
    <path d="M16 28 L25 37 L42 20" stroke="#2E5239" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    <path d="M28 4 L29.5 7" stroke="#E8A53F" stroke-width="2.5" stroke-linecap="round" />
    <path d="M52 28 L49 29.5" stroke="#E8A53F" stroke-width="2.5" stroke-linecap="round" />
    <path d="M28 52 L26.5 49" stroke="#E8A53F" stroke-width="2.5" stroke-linecap="round" />
    <path d="M4 28 L7 26.5" stroke="#E8A53F" stroke-width="2.5" stroke-linecap="round" />
  </svg>
  <h2 class="celebration__title">{t(lang, 'celebration.title')}</h2>
  <p class="celebration__body">{t(lang, 'celebration.body')}</p>
</section>
